# Пример переменных окружения. В Host Manager задаются в форме «Создать/Редактировать сервис».
# PORT и HOST подставляет сам Host Manager — здесь не задавать.

SECRET_KEY=change-me

# --- Корпоративный SMTP (рассылка долгов) ---
SMTP_HOST=mail.med.permkrai.ru
SMTP_PORT=587
SMTP_USER=osacrb-semd@med.permkrai.ru
SMTP_PASS=
SMTP_FROM=osacrb-semd@med.permkrai.ru
SMTP_FROM_NAME=ГБУЗ ПК «Осинская ЦРБ» — мониторинг СЭМД
SMTP_TLS=1
# Тест без реальной отправки: 1 = только логировать
SMTP_DRYRUN=1

# --- FreeIPA (получение корпоративных почт по ФИО) ---
IPA_LDAP_URI=ldaps://ipa.osacrb.local
IPA_BASE_DN=cn=users,cn=accounts,dc=osacrb,dc=local
IPA_BIND_DN=uid=semd-svc,cn=users,cn=accounts,dc=osacrb,dc=local
IPA_BIND_PW=
